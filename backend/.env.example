# Application
APP_NAME=IQX Backend
APP_VERSION=0.1.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/iqx

# JWT
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SePay Payment Gateway
SEPAY_MERCHANT_ID=your_merchant_id
SEPAY_SECRET_KEY=your_secret_key
SEPAY_IPN_SECRET=your_ipn_secret_key
SEPAY_ENV=sandbox

# SePay URLs — configured explicitly because SePay docs have inconsistencies
# between pgapi-sandbox.sepay.vn and pay-sandbox.sepay.vn for checkout.
# For sandbox, use: https://pay-sandbox.sepay.vn/v1/checkout/init
# For production, use: https://pay.sepay.vn/v1/checkout/init
SEPAY_CHECKOUT_URL=https://pay-sandbox.sepay.vn/v1/checkout/init

# SePay REST API base URL (for order detail, cancel, void)
# Sandbox: https://pgapi-sandbox.sepay.vn
# Production: https://pgapi.sepay.vn
SEPAY_API_BASE_URL=https://pgapi-sandbox.sepay.vn

# Payment return URLs (frontend base URL for SePay redirects)
PAYMENT_RETURN_BASE_URL=http://localhost:3000
