# Application Settings
APP_NAME=IQX API
APP_VERSION=1.0.0
APP_DESCRIPTION=IQX Backend API Service
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/iqx_db

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
