# ──────────────────────────────────────────────
# IQX Backend — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# Application
APP_NAME=IQX
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# Database (PostgreSQL + asyncpg)
DATABASE_URL=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@127.0.0.1:5432/YOUR_DB

# JWT Secrets — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY
JWT_REFRESH_SECRET_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_SECRET_KEY
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
