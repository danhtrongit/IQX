# Ignore everything at the repository root by default.
/*

# Keep the root gitignore itself.
!/.gitignore

# Only track the application directories.
!/frontend/
!/frontend/**
!/backend/
!/backend/**
!/dashboard/
!/dashboard/**
!/admin/
!/admin/**
!/admin-bak/
!/admin-bak/**

# Safety guard if the frontend was previously a standalone repo.
/frontend/.git

# OS noise.
.DS_Store
